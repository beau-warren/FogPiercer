# Copy this file to .env locally. Do not commit real secrets.

# Mercury II / Inception model API access.
MERCURY_II_API_KEY=
MERCURY_II_BASE_URL=https://api.inceptionlabs.ai/v1
MERCURY_II_MODEL=mercury-2

# Hugging Face model storage for the trained Logit Hierarchical Regression model.
HF_TOKEN=
FOGPIERCER_HF_MODEL_REPO=beau-warren/SCSP_fogpiercer-logit-hierarchical-regression

# Optional: GitHub token for later automation. Do not use this unless needed.
GITHUB_TOKEN=

# Local prepared CDB90 training table generated by fogpiercer_lhr.prepare_cdb90.
CDB90_DATA_PATH=logit_hierarchical_regression/data/processed/cdb90_model_table.csv

